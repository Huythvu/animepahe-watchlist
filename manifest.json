{
  "manifest_version": 3,
  "name": "Animepahe Watchlist",
  "version": "1.0.0",
  "description": "Adds a Currently Watching and Plan to Watch list to Animepahe.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://animepahe.pw/*",
    "https://graphql.anilist.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://animepahe.pw/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}